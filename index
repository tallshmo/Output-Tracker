<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Output Tracker - Scoreboard</title>
    <!-- Tailwind CSS for utility styles -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts for retro scoreboard typography -->
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,600;0,700;0,800;1,700&family=Share+Tech+Mono&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #0f172a;
        }
        
        /* Athletic, retro condensed typography for scoreboard headers */
        .font-scoreboard {
            font-family: 'Barlow Condensed', sans-serif;
            letter-spacing: 0.05em;
        }

        /* Digital LCD display look for scoreboard values */
        .font-digital {
            font-family: 'Share Tech Mono', monospace;
        }

        /* Chalkboard green scoreboard style with fallback solid background */
        .scoreboard-bg {
            background-color: #13503c !important; /* Exact color match for stadium scoreboard */
            background-image: radial-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 0),
                              radial-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 0);
            background-size: 8px 8px;
            background-position: 0 0, 4px 4px;
        }

        /* Direct CSS container styles to bypass any broken Tailwind dependencies */
        #scoreboard-container {
            background-color: #13503c;
            border: 4px solid #f1f5f9;
            border-radius: 0.5rem;
        }

        /* Custom glow for active neon elements */
        .neon-glow-green {
            box-shadow: 0 0 12px rgba(22, 242, 22, 0.8), inset 0 0 6px rgba(22, 242, 22, 0.4);
        }

        .neon-text-yellow {
            text-shadow: 0 0 10px rgba(254, 240, 138, 0.7), 0 0 20px rgba(234, 179, 8, 0.5);
        }

        /* Grid box styling matching OUTPUT SCOREBOARD.png */
        .tracker-box {
            aspect-ratio: 1 / 1;
            border: 2px solid #000000;
            transition: all 0.15s ease-in-out;
            min-width: 15px;
            min-height: 15px;
        }

        /* Robust, CSS-driven digit block defaults to protect layout */
        .digit-box {
            background-color: #050505;
            border: 2px solid #151515;
            color: #facc15; /* Yellow-400 */
            width: 2rem;
            height: 3rem;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Share Tech Mono', monospace;
            font-size: 1.875rem;
            font-weight: 700;
            border-radius: 0.25rem;
        }

        @media (min-width: 768px) {
            .digit-box {
                width: 3.5rem;
                height: 5rem;
                font-size: 3.75rem;
            }
        }

        /* Scoreboard inner frame styled with clean pure CSS */
        .inner-frame {
            border: 2px solid #ffffff;
            border-radius: 0.25rem;
            padding: 0.75rem;
        }

        @media (min-width: 768px) {
            .inner-frame {
                padding: 1.5rem;
            }
        }

        /* Title heading safe CSS styles */
        .scoreboard-title {
            font-size: 2.25rem;
            font-weight: 800;
            color: #ffffff;
            text-align: center;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            font-family: 'Barlow Condensed', sans-serif;
            margin-bottom: 1.5rem;
        }

        @media (min-width: 768px) {
            .scoreboard-title {
                font-size: 4.5rem;
                margin-bottom: 2rem;
            }
        }
    </style>
</head>
<body class="min-h-screen text-slate-100 py-6 px-4 flex flex-col items-center justify-start gap-6">

    <!-- Top Information Banner -->
    <div class="w-full max-w-4xl flex flex-col md:flex-row items-center justify-between gap-4 bg-slate-900 border border-slate-800 p-4 rounded-xl shadow-lg">
        <div class="flex items-center gap-3">
            <span class="text-3xl">📝</span>
            <div>
                <h1 class="text-lg font-bold text-white">Monthly Output Tracker</h1>
                <p class="text-xs text-slate-400">Designed from <span class="text-teal-400 font-semibold">OUTPUT SCOREBOARD.png</span>. Interactive & Savable.</p>
            </div>
        </div>
        <div class="flex items-center gap-2">
            <button onclick="resetTracker()" class="px-3 py-1.5 text-xs font-semibold uppercase bg-rose-600/20 text-rose-300 border border-rose-500/30 rounded-lg hover:bg-rose-600/40 active:scale-95 transition-all">
                Reset Progress
            </button>
            <button onclick="toggleConfigPanel()" class="px-3 py-1.5 text-xs font-semibold uppercase bg-teal-600/20 text-teal-300 border border-teal-500/30 rounded-lg hover:bg-teal-600/40 active:scale-95 transition-all">
                Adjust Goals
            </button>
        </div>
    </div>

    <!-- MAIN SCOREBOARD WORKSPACE -->
    <div id="scoreboard-container" class="w-full max-w-4xl scoreboard-bg shadow-2xl relative select-none">
        
        <!-- Scoreboard Outer Double Border Frame (Mimicking classic retro boards) -->
        <div class="inner-frame">
            
            <!-- Main Scoreboard Title Header -->
            <div>
                <h2 class="scoreboard-title">
                    OUTPUT TRACKER
                </h2>
            </div>

            <!-- Tracker Box Alignment Grid -->
            <div class="grid grid-cols-12 gap-0 mb-8 max-w-3xl mx-auto">
                <!-- Row of Numbers (Header) -->
                <div class="col-span-4 md:col-span-3"></div>
                <div class="col-span-8 md:col-span-9 grid grid-cols-12 gap-1 text-center font-scoreboard text-base md:text-2xl text-white font-bold mb-1">
                    <div>1</div>
                    <div>2</div>
                    <div>3</div>
                    <div>4</div>
                    <div>5</div>
                    <div>6</div>
                    <div>7</div>
                    <div>8</div>
                    <div>9</div>
                    <div>10</div>
                    <div>11</div>
                    <div>12</div>
                </div>

                <!-- Row 1: 2 ARTICLES -->
                <div class="col-span-4 md:col-span-3 flex items-center pr-2">
                    <span class="font-scoreboard text-white text-lg md:text-3xl font-extrabold tracking-wide uppercase leading-none">
                        2 ARTICLES
                    </span>
                </div>
                <div class="col-span-8 md:col-span-9 grid grid-cols-12 gap-1" id="row-double-boxes">
                    <!-- Boxes loaded dynamically via JS -->
                </div>

                <!-- Row Spacer -->
                <div class="col-span-12 h-4"></div>

                <!-- Row 2: 1 ARTICLE -->
                <div class="col-span-4 md:col-span-3 flex items-center pr-2">
                    <span class="font-scoreboard text-white text-lg md:text-3xl font-extrabold tracking-wide uppercase leading-none">
                        1 ARTICLE
                    </span>
                </div>
                <div class="col-span-8 md:col-span-9 grid grid-cols-12 gap-1" id="row-single-boxes">
                    <!-- Boxes loaded dynamically via JS -->
                </div>
            </div>

            <!-- White Scoreboard Divider -->
            <div class="border-t-4 border-white my-6 md:my-8"></div>

            <!-- Bottom Section Metrics (Goal, Hits, Double, Single) -->
            <div class="max-w-3xl mx-auto">
                
                <!-- Metrics Labels -->
                <div class="grid grid-cols-4 text-center font-scoreboard text-white text-lg md:text-3xl font-extrabold uppercase mb-2">
                    <div>GOAL</div>
                    <div>HITS</div>
                    <div>DOUBLE</div>
                    <div>SINGLE</div>
                </div>

                <!-- Metrics Segment Displays (Scoreboard Digits) -->
                <div class="grid grid-cols-4 gap-2 md:gap-4">
                    
                    <!-- GOAL DISPLAY -->
                    <div class="flex justify-center items-center gap-1 bg-black/60 p-2 rounded border border-white/10">
                        <div id="goal-tens" class="digit-box neon-text-yellow">-</div>
                        <div id="goal-ones" class="digit-box neon-text-yellow">-</div>
                    </div>

                    <!-- HITS DISPLAY -->
                    <div class="flex justify-center items-center gap-1 bg-black/60 p-2 rounded border border-white/10">
                        <div id="hits-tens" class="digit-box neon-text-yellow">-</div>
                        <div id="hits-ones" class="digit-box neon-text-yellow">-</div>
                    </div>

                    <!-- DOUBLE REMAINING DISPLAY -->
                    <div class="flex justify-center items-center gap-1 bg-black/60 p-2 rounded border border-white/10">
                        <div id="double-tens" class="digit-box neon-text-yellow">-</div>
                        <div id="double-ones" class="digit-box neon-text-yellow">-</div>
                    </div>

                    <!-- SINGLE REMAINING DISPLAY -->
                    <div class="flex justify-center items-center gap-1 bg-black/60 p-2 rounded border border-white/10">
                        <div id="single-tens" class="digit-box neon-text-yellow">-</div>
                        <div id="single-ones" class="digit-box neon-text-yellow">-</div>
                    </div>

                </div>

            </div>

        </div>

    </div>

    <!-- COLLAPSIBLE DYNAMIC TARGET CONFIGURATION PANEL -->
    <div id="config-panel" class="w-full max-w-4xl bg-slate-900 border border-slate-800 p-6 rounded-xl shadow-xl transition-all duration-300 hidden">
        <div class="flex items-center justify-between border-b border-slate-800 pb-3 mb-4">
            <h3 class="text-md font-semibold text-slate-200 uppercase tracking-wider flex items-center gap-2">
                ⚙️ Goal & Visual Configurator
            </h3>
            <button onclick="toggleConfigPanel()" class="text-slate-400 hover:text-white text-sm">✕ Close</button>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Slider for Double Target Days -->
            <div class="bg-slate-950 p-4 rounded-lg border border-slate-800/60">
                <div class="flex justify-between items-center mb-2">
                    <label class="text-sm font-medium text-slate-300">2-Article Target Days:</label>
                    <span id="target-double-val" class="px-2 py-0.5 bg-teal-500/10 text-teal-300 border border-teal-500/30 rounded text-xs font-bold">12 Days</span>
                </div>
                <input type="range" id="target-double-slider" min="0" max="12" value="12" class="w-full h-2 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-teal-400" oninput="updateTargetConfig()">
                <p class="text-xs text-slate-400 mt-2">Adjust the number of days you want to write 2 articles. Days beyond this limit will be crossed out (e.g., box 12).</p>
            </div>

            <!-- Slider for Single Target Days -->
            <div class="bg-slate-950 p-4 rounded-lg border border-slate-800/60">
                <div class="flex justify-between items-center mb-2">
                    <label class="text-sm font-medium text-slate-300">1-Article Target Days:</label>
                    <span id="target-single-val" class="px-2 py-0.5 bg-teal-500/10 text-teal-300 border border-teal-500/30 rounded text-xs font-bold">11 Days</span>
                </div>
                <input type="range" id="target-single-slider" min="0" max="12" value="11" class="w-full h-2 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-teal-400" oninput="updateTargetConfig()">
                <p class="text-xs text-slate-400 mt-2">Adjust the number of days you want to write 1 article. Days beyond this limit will be crossed out.</p>
            </div>
        </div>

        <div class="mt-6 pt-4 border-t border-slate-800 flex justify-between items-center">
            <div class="text-xs text-slate-400 flex items-center gap-2">
                <span>🔔</span>
                <span>Configuring these dynamically recalculates the <strong>Goal</strong> metric and adds scoreboard crossed out boxes!</span>
            </div>
            <button onclick="applyScoreboardPreset()" class="px-3 py-1 bg-slate-800 text-slate-200 border border-slate-700 hover:bg-slate-700 text-xs rounded transition-colors">
                Apply Preset (OUTPUT SCOREBOARD.png)
            </button>
        </div>
    </div>

    <!-- Celebration Banner / Goal Completed Alert -->
    <div id="celebration-banner" class="w-full max-w-4xl bg-gradient-to-r from-emerald-600 to-teal-600 text-white p-4 rounded-xl shadow-lg flex items-center justify-between hidden transition-all">
        <div class="flex items-center gap-3">
            <span class="text-2xl">🎉</span>
            <div>
                <h4 class="font-bold">Goal Completed!</h4>
                <p class="text-xs opacity-90">Outstanding job! You've matched or exceeded your monthly article output goal!</p>
            </div>
        </div>
        <button onclick="closeCelebration()" class="text-white hover:opacity-85 font-semibold text-sm">✕</button>
    </div>

    <!-- CORE SYSTEM SCRIPT WITH STORAGE FAILSAFES -->
    <script>
        // Default initial application state matching OUTPUT SCOREBOARD.png
        let state = {
            targetDoubleDays: 12,
            targetSingleDays: 11,
            doubleProgress: [true, true, true, false, false, false, false, false, false, false, false, false],
            singleProgress: [true, true, true, true, false, false, false, false, false, false, false, false]
        };

        // Failsafe wrapper to safely obtain browser storage settings
        function safeGetItem(key) {
            try {
                return localStorage.getItem(key);
            } catch (error) {
                console.warn("Storage access restricted by browser settings. Operating in-memory fallback.", error);
                return null;
            }
        }

        // Failsafe wrapper to safely update browser storage settings
        function safeSetItem(key, value) {
            try {
                localStorage.setItem(key, value);
            } catch (error) {
                // Silently absorb security exceptions in restricted iframes
            }
        }

        // Initialization routine (Bypasses window.onload timing bugs)
        function initScoreboard() {
            const savedState = safeGetItem('monthly_writing_scoreboard_state');
            if (savedState) {
                try {
                    const parsed = JSON.parse(savedState);
                    if (parsed && typeof parsed === 'object') {
                        state.targetDoubleDays = typeof parsed.targetDoubleDays === 'number' ? parsed.targetDoubleDays : 12;
                        state.targetSingleDays = typeof parsed.targetSingleDays === 'number' ? parsed.targetSingleDays : 11;
                        state.doubleProgress = Array.isArray(parsed.doubleProgress) ? parsed.doubleProgress : Array(12).fill(false);
                        state.singleProgress = Array.isArray(parsed.singleProgress) ? parsed.singleProgress : Array(12).fill(false);
                    }
                } catch (e) {
                    console.error("Could not parse saved storage progress. Reverting to preset.", e);
                    loadDefaultPreset();
                }
            } else {
                loadDefaultPreset();
            }

            // Sync Slider elements to current values
            const doubleSlider = document.getElementById('target-double-slider');
            const singleSlider = document.getElementById('target-single-slider');
            
            if (doubleSlider && singleSlider) {
                doubleSlider.value = state.targetDoubleDays;
                singleSlider.value = state.targetSingleDays;
            }
            
            // Sync slider badges
            const doubleVal = document.getElementById('target-double-val');
            const singleVal = document.getElementById('target-single-val');
            if (doubleVal && singleVal) {
                doubleVal.textContent = `${state.targetDoubleDays} Days`;
                singleVal.textContent = `${state.targetSingleDays} Days`;
            }

            renderScoreboard();
        }

        // Execute initialization directly or hook into listener
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initScoreboard);
        } else {
            initScoreboard();
        }

        // Load the exact preset from OUTPUT SCOREBOARD.png
        function loadDefaultPreset() {
            state.targetDoubleDays = 12;
            state.targetSingleDays = 11;
            
            // 3 double-days complete
            state.doubleProgress = [true, true, true, false, false, false, false, false, false, false, false, false];
            // 4 single-days complete
            state.singleProgress = [true, true, true, true, false, false, false, false, false, false, false, false];
        }

        // Apply visual and functional preset on user request
        function applyScoreboardPreset() {
            loadDefaultPreset();
            // Sync slider UI elements
            document.getElementById('target-double-slider').value = 12;
            document.getElementById('target-single-slider').value = 11;
            document.getElementById('target-double-val').textContent = `12 Days`;
            document.getElementById('target-single-val').textContent = `11 Days`;
            saveAndRender();
        }

        // Save State & Update Render
        function saveAndRender() {
            safeSetItem('monthly_writing_scoreboard_state', JSON.stringify(state));
            renderScoreboard();
        }

        // Toggle configuration panel visibility
        function toggleConfigPanel() {
            const panel = document.getElementById('config-panel');
            panel.classList.toggle('hidden');
        }

        // Dynamic config adjustments from slider changes
        function updateTargetConfig() {
            const doubleSlider = document.getElementById('target-double-slider');
            const singleSlider = document.getElementById('target-single-slider');

            state.targetDoubleDays = parseInt(doubleSlider.value);
            state.targetSingleDays = parseInt(singleSlider.value);

            // Sync display slider badges
            document.getElementById('target-double-val').textContent = `${state.targetDoubleDays} Days`;
            document.getElementById('target-single-val').textContent = `${state.targetSingleDays} Days`;

            saveAndRender();
        }

        // Handle box clicks
        function toggleDoubleBox(index) {
            // Cannot toggle if it is beyond active target days (crossed out)
            if (index >= state.targetDoubleDays) return;
            state.doubleProgress[index] = !state.doubleProgress[index];
            saveAndRender();
        }

        function toggleSingleBox(index) {
            // Cannot toggle if it is beyond active target days (crossed out)
            if (index >= state.targetSingleDays) return;
            state.singleProgress[index] = !state.singleProgress[index];
            saveAndRender();
        }

        // Reset All progress logic (safe alternative to native confirm block)
        function resetTracker() {
            const customConfirm = window.confirm("Are you sure you want to reset all checked progress blocks? Goal settings will remain.");
            if (customConfirm) {
                state.doubleProgress = Array(12).fill(false);
                state.singleProgress = Array(12).fill(false);
                saveAndRender();
            }
        }

        // Close goal celebration alert
        function closeCelebration() {
            document.getElementById('celebration-banner').classList.add('hidden');
        }

        // Update Digit Blocks with Retro Scoreboard Character formatting
        function updateDigitDisplay(prefixId, val) {
            // Ensure score values are clamped between 0 and 99
            let clampedVal = Math.max(0, Math.min(99, val));
            
            // Format to 2-digit string
            let valStr = clampedVal.toString();
            let tensDigit = " "; // empty space represents turned-off segment block
            let onesDigit = "0";

            if (valStr.length === 1) {
                onesDigit = valStr[0];
            } else {
                tensDigit = valStr[0];
                onesDigit = valStr[1];
            }

            const tensElement = document.getElementById(`${prefixId}-tens`);
            const onesElement = document.getElementById(`${prefixId}-ones`);

            if (tensElement && onesElement) {
                // Apply character content
                tensElement.textContent = tensDigit;
                onesElement.textContent = onesDigit;

                // Highlight active / non-empty digit boxes matching the image styling
                if (tensDigit === " " || tensDigit === "0") {
                    // Dim down non-active characters
                    tensElement.classList.add('opacity-30');
                } else {
                    tensElement.classList.remove('opacity-30');
                }
            }
        }

        // Main Rendering Pipeline
        function renderScoreboard() {
            // Goal: (Target Double * 2) + (Target Single * 1)
            const goalValue = (state.targetDoubleDays * 2) + (state.targetSingleDays * 1);

            // Calculate completed Hits
            let activeDoubleCount = 0;
            state.doubleProgress.forEach((checked, idx) => {
                if (checked && idx < state.targetDoubleDays) activeDoubleCount++;
            });

            let activeSingleCount = 0;
            state.singleProgress.forEach((checked, idx) => {
                if (checked && idx < state.targetSingleDays) activeSingleCount++;
            });

            const hitsValue = (activeDoubleCount * 2) + (activeSingleCount * 1);

            // Calculate remaining slots
            const doubleRemaining = Math.max(0, state.targetDoubleDays - activeDoubleCount);
            const singleRemaining = Math.max(0, state.targetSingleDays - activeSingleCount);

            // Update UI Scoreboard digits
            updateDigitDisplay('goal', goalValue);
            updateDigitDisplay('hits', hitsValue);
            updateDigitDisplay('double', doubleRemaining);
            updateDigitDisplay('single', singleRemaining);

            // Render Row 1: 2 Articles
            const doubleContainer = document.getElementById('row-double-boxes');
            if (doubleContainer) {
                doubleContainer.innerHTML = '';
                for (let i = 0; i < 12; i++) {
                    const boxDiv = document.createElement('div');
                    boxDiv.className = 'tracker-box relative cursor-pointer';

                    if (i >= state.targetDoubleDays) {
                        // CROSSED OUT BOX (Beyond Goal Range)
                        boxDiv.classList.add('bg-black/40', 'cursor-not-allowed');
                        boxDiv.innerHTML = `
                            <svg class="absolute inset-0 w-full h-full text-black stroke-[3.5]" viewBox="0 0 100 100" preserveAspectRatio="none">
                                <line x1="0" y1="0" x2="100" y2="100" stroke="currentColor"></line>
                                <line x1="100" y1="0" x2="0" y2="100" stroke="currentColor"></line>
                            </svg>
                        `;
                    } else {
                        // Clickable Box
                        boxDiv.onclick = () => toggleDoubleBox(i);
                        if (state.doubleProgress[i]) {
                            // Neon active green fill
                            boxDiv.classList.add('bg-[#1bfd1b]', 'neon-glow-green');
                        } else {
                            // Dark uncompleted state
                            boxDiv.classList.add('bg-transparent', 'hover:bg-white/10');
                        }
                    }
                    doubleContainer.appendChild(boxDiv);
                }
            }

            // Render Row 2: 1 Article
            const singleContainer = document.getElementById('row-single-boxes');
            if (singleContainer) {
                singleContainer.innerHTML = '';
                for (let i = 0; i < 12; i++) {
                    const boxDiv = document.createElement('div');
                    boxDiv.className = 'tracker-box relative cursor-pointer';

                    if (i >= state.targetSingleDays) {
                        // CROSSED OUT BOX (Beyond Goal Range)
                        boxDiv.classList.add('bg-black/40', 'cursor-not-allowed');
                        boxDiv.innerHTML = `
                            <svg class="absolute inset-0 w-full h-full text-black stroke-[3.5]" viewBox="0 0 100 100" preserveAspectRatio="none">
                                <line x1="0" y1="0" x2="100" y2="100" stroke="currentColor"></line>
                                <line x1="100" y1="0" x2="0" y2="100" stroke="currentColor"></line>
                            </svg>
                        `;
                    } else {
                        // Clickable Box
                        boxDiv.onclick = () => toggleSingleBox(i);
                        if (state.singleProgress[i]) {
                            // Neon active green fill
                            boxDiv.classList.add('bg-[#1bfd1b]', 'neon-glow-green');
                        } else {
                            boxDiv.classList.add('bg-transparent', 'hover:bg-white/10');
                        }
                    }
                    singleContainer.appendChild(boxDiv);
                }
            }

            // Handle celebration panel logic
            const celebration = document.getElementById('celebration-banner');
            if (celebration) {
                if (hitsValue >= goalValue && goalValue > 0) {
                    celebration.classList.remove('hidden');
                } else {
                    celebration.classList.add('hidden');
                }
            }
        }
    </script>
</body>
</html>
